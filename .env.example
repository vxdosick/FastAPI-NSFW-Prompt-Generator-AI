# Telegram
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-example-token
BOT_LINK=https://t.me/your_bot_username

# Server (public URL for webhooks and checkout; use ngrok URL locally)
SERVER_URL=https://your-app.onrender.com
LEGAL_PAGE_URL=https://nsfwprompts.app/terms

# Dev bot (local testing via ngrok — prod bot on Render keeps working)
DEV_BOT_TOKEN=1234567890:ABCdefGHI-dev-bot-token
DEV_BOT_LINK=https://t.me/your_dev_bot_username
DEV_SERVER_URL=https://your-ngrok-subdomain.ngrok-free.app
# Set true in .env only while running uvicorn locally with the dev bot
USE_DEV_BOT=false

# Stripe (live keys from Stripe Dashboard)
STRIPE_LIVE_SECRET_KEY=your_stripe_live_secret_key
STRIPE_LIVE_WEBHOOK_SECRET=your_stripe_webhook_secret

# OpenRouter
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=openrouter-ai-model

# Payments
PAYMENT_CONTENT=100 Generations 🤗
PAYMENT_EURO_PRICE=199
PAYMENT_STARS_PRICE=120
PAYMENT_BOT_CREDITS=100

# Owner (optional: extra starting credits for your Telegram user id)
OWNER_TELEGRAM_ID=123456789
OWNER_START_CREDITS=10000

# Maintenance (true = all users except OWNER_TELEGRAM_ID see a maintenance message)
MAINTENANCE_MODE=false

# Database (Neon PostgreSQL, async driver)
POSTGRES_URL=postgresql+asyncpg://user:password@host.neon.tech/dbname?sslmode=require

# Support contact shown in /contacts (@username, not a full URL)
SUPPORT_TELEGRAM=@your_support_username

# Saved prompts (max number of saved prompts)
MAX_SAVED_PROMPTS=5
